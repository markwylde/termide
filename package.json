{
  "name": "termide",
  "productName": "Termide",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop terminal workspace built with Electron, React, and Vite.",
  "author": "Mark Wylde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:markwylde/termide.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc && vite build && electron-builder --dir --mac --arm64 && open \"release/$npm_package_version/mac-arm64/Termide.app\"",
    "build:app": "tsc && vite build",
    "build": "npm run build:app && electron-builder --publish never",
    "build:mac": "npm run build:app && electron-builder --mac dmg --publish never",
    "build:linux": "npm run build:app && electron-builder --linux AppImage --publish never",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "smoke": "npm run lint && npm run build:app",
    "release": "semantic-release",
    "test:release-config": "node --test scripts/release-config.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^5.1.0",
    "framer-motion": "^12.38.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
